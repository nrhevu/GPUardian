# syntax=docker/dockerfile:1.7

ARG NODE_VERSION=24.16.0
ARG GO_VERSION=1.26.5

FROM node:${NODE_VERSION}-bookworm-slim AS ui-build
ENV npm_config_audit=false \
    npm_config_fund=false
WORKDIR /src/web/ui
COPY web/ui/package.json web/ui/package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci
COPY web/ui/index.html ./
COPY web/ui/public ./public
COPY web/ui/src ./src
RUN npm run build

FROM golang:${GO_VERSION}-bookworm AS go-build
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 go build -trimpath -buildvcs=false -ldflags="-s -w" \
    -o /out/rocguard ./cmd/rocguard

FROM gcr.io/distroless/static-debian12:nonroot
LABEL org.opencontainers.image.title="RocGuard web gateway" \
      org.opencontainers.image.description="Non-root RocGuard web gateway and UI"
COPY --from=go-build /out/rocguard /usr/local/bin/rocguard
COPY --from=ui-build /src/web/ui/dist /usr/local/share/rocguard/ui
WORKDIR /var/lib/rocguard-web
USER 65532:65532
EXPOSE 8080 8443
ENTRYPOINT ["/usr/local/bin/rocguard"]
CMD ["web"]
